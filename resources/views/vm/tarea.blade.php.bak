    <div class="modal-footer">
      <button class="btn" onclick="closeModal('modal-personas')">Cancelar</button>
      <button class="btn btn-primary" style="background:{{ $c['bd'] }}" onclick="guardarAsignados()">Guardar</button>
    </div>
  </div>
</div>

{{-- ── MODAL IMPUTACIÓN ── --}}
<div class="modal-overlay" id="modal-imp">
  <div class="modal">
    <div class="modal-title">Añadir imputación</div>
    <label>Persona</label>
    <select id="imp-usuario">
      <option value="">— Selecciona —</option>
      @foreach ($usuarios as $u)
        <option value="{{ $u->id }}">{{ $u->nombre }}</option>
      @endforeach
    </select>
    <div class="form-row">
      <div>
        <label>Fecha</label>
        <input type="date" id="imp-fecha" value="{{ date('Y-m-d') }}">
      </div>
      <div>
        <label>Duración (minutos)</label>
        <input type="number" id="imp-duracion" min="1" placeholder="60">
      </div>
    </div>
    <label>Observación (opcional)</label>
    <textarea id="imp-obs" rows="2" placeholder="Observación..."></textarea>
    <div class="modal-footer">
      <button class="btn" onclick="closeModal('modal-imp')">Cancelar</button>
      <button class="btn btn-primary" style="background:{{ $c['bd'] }}" onclick="guardarImputacion()">Guardar</button>
    </div>
  </div>
</div>

<script>
const CSRF = '{{ $csrf }}';
const COLOR_TX  = '{{ $c['tx'] }}';
const COLOR_BG  = '{{ $c['bg'] }}';
const COLOR_BAR = '{{ $c['bar'] }}';
const URL_UPDATE    = '{{ $urlUpdate }}';
const URL_ASIGNADOS = '{{ $urlAsignados }}';
const URL_IMP_STORE = '{{ $urlImpStore }}';
const URL_IMP_DEL   = '{{ $urlImpDel }}';

// ── Edit mode ──
function enterEdit() {
    document.getElementById('main-card').classList.add('editing');
    document.getElementById('btn-view-mode').style.display = 'none';
    document.getElementById('btn-edit-mode').style.display = 'flex';
}
function cancelEdit() {
    document.getElementById('main-card').classList.remove('editing');
    document.getElementById('btn-view-mode').style.display = 'flex';
    document.getElementById('btn-edit-mode').style.display = 'none';
}
function guardar() {
    document.getElementById('f-nombre').value      = document.getElementById('inp-nombre').value;
    document.getElementById('f-descripcion').value = document.getElementById('inp-desc').value;
    document.getElementById('f-comentario').value  = document.getElementById('inp-com').value;
    document.getElementById('f-fecha').value       = document.getElementById('inp-fecha').value;
    document.getElementById('f-tipo').value        = document.getElementById('inp-tipo').value;
    document.getElementById('form-tarea').submit();
}

// ── Modals ──
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-overlay').forEach(m =>
    m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); })
);

// ── Personas asignadas ──
function minToHm(min) {
    if (min <= 0) return '0h 00m';
    return Math.floor(min/60) + 'h ' + String(min%60).padStart(2,'0') + 'm';
}
function iniciales(nombre) {
    return nombre.split(' ').slice(0,2).map(p => (p[0]||'').toUpperCase()).join('');
}

async function guardarAsignados() {
    const ids = [...document.querySelectorAll('#user-check-list input:checked')].map(cb => parseInt(cb.value));
    const r = await fetch(URL_ASIGNADOS, {
        method: 'PATCH',
        headers: {'Content-Type':'application/json','X-CSRF-TOKEN':CSRF,'Accept':'application/json'},
        body: JSON.stringify({ids})
    });
    const data = await r.json();
    if (data.ok) {
        closeModal('modal-personas');
        // Rebuild asgn-list from checked
        const list = document.getElementById('asgn-list');
        list.innerHTML = '';
        const checked = document.querySelectorAll('#user-check-list input:checked');
        if (!checked.length) {
            const p = document.createElement('p');
            p.id = 'asgn-empty';
            p.style.cssText = 'font-size:13px;color:var(--text-muted);margin:0';
            p.textContent = 'Sin personas asignadas.';
            list.appendChild(p);
        } else {
            checked.forEach(cb => {
                const nombre = cb.closest('label').querySelector('span').textContent;
                const uid = parseInt(cb.value);
                const row = document.createElement('div');
                row.className = 'asgn-row';
                row.id = 'asgn-' + uid;
                row.innerHTML = `
                    <div class="t-avatar" style="background:var(--surface-1);color:var(--text-muted)">${iniciales(nombre)}</div>
                    <div class="asgn-info">
                        <div class="asgn-name">${nombre}</div>
                        <div class="bar-wrap"><div class="bar-fill" style="width:0%;background:${COLOR_BAR}"></div></div>
                    </div>
                    <span class="no-imp-txt">Sin imputar</span>`;
                list.appendChild(row);
            });
        }
        const n = ids.length;
        document.getElementById('meta-asignadas-count').textContent = n + ' ' + (n === 1 ? 'persona' : 'personas');

        // Update modal-imp select with new users
        const sel = document.getElementById('imp-usuario');
        sel.innerHTML = '<option value="">— Selecciona —</option>';
        checked.forEach(cb => {
            const nombre = cb.closest('label').querySelector('span').textContent;
            const opt = document.createElement('option');
            opt.value = cb.value;
            opt.textContent = nombre;
            sel.appendChild(opt);
        });
    }
}

// ── Imputaciones ──
let impTotal = {{ $totalImputado }};

function updateImpTotals() {
    const hm = minToHm(impTotal);
    document.getElementById('imp-total-head').textContent = impTotal ? hm : 'Ninguna';
    const foot = document.getElementById('imp-total-foot');
    if (foot) foot.textContent = hm;
    document.getElementById('imp-foot').style.display = impTotal ? '' : 'none';
    @if ($tipo === 'limpieza')
    const durEl = document.getElementById('dur-total');
    if (durEl) durEl.textContent = impTotal ? hm : 'Sin imputar';
    @endif
}

async function eliminarImputacion(impId, btn) {
    if (!confirm('¿Eliminar esta imputación?')) return;
    btn.disabled = true;
    const r = await fetch(URL_IMP_DEL + '/' + impId, {
        method: 'DELETE',
        headers: {'X-CSRF-TOKEN':CSRF,'Accept':'application/json'}
    });
    const data = await r.json();
    if (data.ok) {
        const row = document.getElementById('imp-' + impId);
        impTotal -= parseInt(row?.dataset.dur || 0);
        row?.remove();
        updateImpTotals();
        if (!document.querySelectorAll('#imp-list .imp-row').length) {
            const empty = document.createElement('div');
            empty.className = 'imp-empty'; empty.id = 'imp-empty';
            empty.innerHTML = '<i class="ti ti-clock-pause"></i><p>Nadie ha imputado tiempo todavía.</p>';
            document.getElementById('imp-list').appendChild(empty);
        }
    }
    btn.disabled = false;
}

async function guardarImputacion() {
    const uid  = parseInt(document.getElementById('imp-usuario').value);
    const fecha = document.getElementById('imp-fecha').value;
    const dur  = parseInt(document.getElementById('imp-duracion').value);
    const obs  = document.getElementById('imp-obs').value.trim();
    if (!uid || !fecha || !dur || dur < 1) { alert('Completa persona, fecha y duración.'); return; }

    const btn = document.querySelector('#modal-imp .btn-primary');
    btn.disabled = true;
    const r = await fetch(URL_IMP_STORE, {
        method: 'POST',
        headers: {'Content-Type':'application/json','X-CSRF-TOKEN':CSRF,'Accept':'application/json'},
        body: JSON.stringify({id_usuario:uid, fecha_imputacion:fecha, duracion:dur, observacion:obs||null})
    });
    const data = await r.json();
    if (data.ok) {
        const imp = data.imp;
        const inis = iniciales(imp.usuario_nombre);
        const fechaFmt = new Date(imp.fecha_imputacion + 'T00:00:00').toLocaleDateString('es-ES',{day:'numeric',month:'short'});
        document.getElementById('imp-empty')?.remove();
        const row = document.createElement('div');
        row.className = 'imp-row'; row.id = 'imp-' + imp.id; row.dataset.dur = imp.duracion;
        row.innerHTML = `
            <div class="imp-avatar" style="background:${COLOR_BG};color:${COLOR_TX}">${inis}</div>
            <div class="imp-main">
                <div class="imp-uname">${imp.usuario_nombre}</div>
                <div class="imp-obs ${imp.observacion?'':'empty'}">${imp.observacion||'Sin observación.'}</div>
            </div>
            <span class="imp-date">${fechaFmt}</span>
            <span class="imp-dur" style="color:${COLOR_TX}">${minToHm(imp.duracion)}</span>
            <button class="btn-del" title="Eliminar" onclick="eliminarImputacion(${imp.id}, this)">
                <i class="ti ti-x" style="font-size:12px"></i>
            </button>`;
        const list = document.getElementById('imp-list');
        const last = list.querySelector('.imp-row:last-child');
        last ? last.after(row) : list.appendChild(row);
        impTotal += imp.duracion;
        updateImpTotals();
        closeModal('modal-imp');
        document.getElementById('imp-usuario').value = '';
        document.getElementById('imp-duracion').value = '';
        document.getElementById('imp-obs').value = '';
    }
    btn.disabled = false;
}
</script>
@endif
</x-app-layout>
